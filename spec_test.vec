// === SPEC COMPLIANCE TEST ===

// Types
print("TYPES:")
print(type(nil))
print(type(true))
print(type(42))
print(type(3.14))
print(type("hello"))
print(type([1,2,3]))
print(type({a: 1}))
print(type(fn(x) { x }))

// Operators - Arithmetic
print("ARITHMETIC:")
print(1 + 2)
print(5 - 3)
print(2 * 3)
print(10 / 2)
print(7 % 3)
print(2 ** 3)

// Operators - Comparison
print("COMPARISON:")
print(1 == 1)
print(1 != 2)
print(1 < 2)
print(2 <= 2)
print(3 > 2)
print(3 >= 3)

// Operators - Logical
print("LOGICAL:")
print(true and false)
print(true or false)
print(not true)

// Operators - Bitwise
print("BITWISE:")
print(5 & 3)
print(5 | 3)
print(5 ^ 3)
print(~0)
print(2 << 3)
print(16 >> 2)

// String concat
print("CONCAT:")
print("a" ++ "b")

// Control flow
print("CONTROL:")
if true { print("if-true") }
if false { print("bad") } else { print("else") }

// Loops
print("LOOPS:")
let mut i = 0
while i < 2 {
    print(i)
    i = i + 1
}
for j in 0..3 {
    print(j)
}
for item in [10, 20] {
    print(item)
}

// Match
print("MATCH:")
print(match 0 { 0 => "zero", _ => "other" })
print(match 5 { 1..10 => "range", _ => "other" })
print(match 99 { 0 => "zero", 1..10 => "range", _ => "wildcard" })

// Functions
print("FUNCTIONS:")
fn add(a, b) {
    return a + b
}
print(add(2, 3))

let double = fn(x) { x * 2 }
print(double(5))

// Tables
print("TABLES:")
let person = { name: "Alice", age: 30 }
print(person.name)
print(person["age"])

// Arrays
print("ARRAYS:")
let arr = [1, 2, 3]
print(arr[0])
print(len(arr))

// String interpolation
print("INTERPOLATION:")
let name = "World"
print("Hello, {name}!")

// Error handling
print("ERRORS:")
let ok_result = try 42
print(ok_result.ok)
print(ok_result.value)

let err_result = try error("test error")
print(err_result.is_err())
print(err_result.err())
